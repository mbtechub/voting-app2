  EXECUTE IMMEDIATE 'CREATE SEQUENCE payments_seq START WITH ' || v_next || ' INCREMENT BY 1 NOCACHE NOCYCLE';

  SELECT NVL(MAX(VOTE_ID), 0) + 1 INTO v_next FROM VOTES;
  EXECUTE IMMEDIATE 'DROP SEQUENCE SEQ_VOTE_ID';
  EXECUTE IMMEDIATE 'CREATE SEQUENCE SEQ_VOTE_ID START WITH ' || v_next || ' INCREMENT BY 1 CACHE 20 NOORDER NOCYCLE';
  EXECUTE IMMEDIATE 'DROP SEQUENCE votes_seq';
  EXECUTE IMMEDIATE 'CREATE SEQUENCE votes_seq START WITH ' || v_next || ' INCREMENT BY 1 NOCACHE NOCYCLE';
END;
