--------------------------------------------------------
-- IMMUTABLE RECEIPTS TRIGGER
--------------------------------------------------------

CREATE OR REPLACE TRIGGER TRG_RECEIPTS_IMMUTABLE
BEFORE UPDATE ON RECEIPTS
FOR EACH ROW
BEGIN
    IF UPPER(:OLD.STATUS) IN ('SUCCESS', 'PARTIALLY_APPLIED') THEN
        IF :OLD.PDF_HASH IS NULL AND :NEW.PDF_HASH IS NOT NULL THEN
            IF UPPER(:NEW.STATUS) <> UPPER(:OLD.STATUS)
               OR :NEW.PAYMENT_ID <> :OLD.PAYMENT_ID
               OR :NEW.CART_ID <> :OLD.CART_ID
               OR :NEW.AMOUNT <> :OLD.AMOUNT
               OR UPPER(:NEW.CURRENCY) <> UPPER(:OLD.CURRENCY)
               OR UPPER(:NEW.PDF_VERSION) <> UPPER(:OLD.PDF_VERSION)
               OR :NEW.SNAPSHOT_HASH <> :OLD.SNAPSHOT_HASH
               OR DBMS_LOB.COMPARE(:NEW.SNAPSHOT_JSON, :OLD.SNAPSHOT_JSON) <> 0
            THEN
                RAISE_APPLICATION_ERROR(-20001, 'Receipt is immutable after finalization (only PDF_HASH may be set once).');
            END IF;
        ELSE
            RAISE_APPLICATION_ERROR(-20001, 'Receipt is immutable after finalization.');
        END IF;
    END IF;
END;
/
ALTER TRIGGER TRG_RECEIPTS_IMMUTABLE ENABLE;
/

